    "cursor",
    "opencode",
    "gemini-cli",
    "openclaw",
    "ai-agents",
    "skills",
    "hooks",
    "recommender",
    "setup",
    "cli"
  ],
  "license": "MIT",
  "homepage": "https://github.com/sukoji/loadout",
